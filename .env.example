# VeritaLog deployment environment (GenLayer Testnet Bradbury)
#
# Copy this file to .env and fill in the value below.
#   cp .env.example .env
#
# ACCOUNT_PRIVATE_KEY is the private key of the account that deploys the
# contract. It signs the deploy transaction on Testnet Bradbury.
#
# - Use a throwaway testnet account, never a mainnet key.
# - Fund it with test GEN first: https://testnet-faucet.genlayer.foundation
# - This value is never logged, printed, or committed. .env is gitignored.

ACCOUNT_PRIVATE_KEY=
